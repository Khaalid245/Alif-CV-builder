# ─── Django Core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-minimum-50-characters
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Environment ──────────────────────────────────────────────────────────────
# Options: development | production
DJANGO_ENVIRONMENT=development

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_NAME=educv_db
DB_USER=educv_user
DB_PASSWORD=your-strong-database-password
DB_HOST=127.0.0.1
DB_PORT=3306

# ─── JWT Settings ─────────────────────────────────────────────────────────────
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_LIFETIME=60
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_LIFETIME=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Flutter app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Media & Static Files ─────────────────────────────────────────────────────
MEDIA_URL=/media/
MEDIA_ROOT=media

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ─── Rate Limiting ────────────────────────────────────────────────────────────
ANON_RATE_LIMIT=20/hour
USER_RATE_LIMIT=200/hour

# ─── Production Only (DigitalOcean Spaces) ────────────────────────────────────
# Uncomment and fill these when deploying to production
# USE_SPACES=False
# AWS_ACCESS_KEY_ID=your-spaces-access-key
# AWS_SECRET_ACCESS_KEY=your-spaces-secret-key
# AWS_STORAGE_BUCKET_NAME=your-spaces-bucket-name
# AWS_S3_ENDPOINT_URL=https://your-region.digitaloceanspaces.com
# AWS_S3_CUSTOM_DOMAIN=your-cdn-domain.com
