# ═══════════════════════════════════════════════════════════════════════════════
# EduCV Backend Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# IMPORTANT: NEVER commit the .env file to version control. Use .env.local for
# development and manage production secrets via environment variables.
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Django Core ──────────────────────────────────────────────────────────────
# SECURITY: Generate a new secret key for each environment
# Development: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Production: Use AWS Secrets Manager or similar
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-minimum-50-characters

# DEBUG MODE: MUST be False in production
# Development: True | Production: False
DJANGO_DEBUG=False

# Comma-separated list of allowed domains
# Development: localhost,127.0.0.1
# Production: yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Environment configuration
# Options: development, staging, production
DJANGO_ENVIRONMENT=development

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
# Database credentials - store in AWS Secrets Manager for production
DB_NAME=educv_db
DB_USER=educv_user
DB_PASSWORD=your-strong-database-password-min-12-chars
DB_HOST=127.0.0.1
DB_PORT=3306

# ─── JWT Settings ─────────────────────────────────────────────────────────────
# Access token lifetime in minutes
# Development: 1440 (24h) | Production: 30-60 (minutes)
JWT_ACCESS_TOKEN_LIFETIME=30

# Refresh token lifetime in days
# Development: 7 days | Production: 14 days
JWT_REFRESH_TOKEN_LIFETIME=14

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Flutter app
# Development: http://localhost:3000,http://localhost:8080
# Production: https://yourdomain.com,https://www.yourdomain.com
# NOTE: Never use regex patterns in production for security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Media & Static Files ─────────────────────────────────────────────────────
MEDIA_URL=/media/
MEDIA_ROOT=media

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Format: requests/time_period (hour, day, etc.)
ANON_RATE_LIMIT=20/hour
USER_RATE_LIMIT=200/hour
PDF_GENERATION_RATE_LIMIT=10/hour

# ─── Email Configuration ──────────────────────────────────────────────────────
# SMTP Server Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ─── Sentry (Error Tracking & Monitoring) ─────────────────────────────────────
# Get DSN from https://sentry.io/settings/projects/
# Leave blank to disable Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Storage Configuration (S3 or DigitalOcean Spaces) ────────────────────────
# Only required for production file storage
USE_SPACES=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# ─── Redis Configuration (if using caching/celery) ───────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
