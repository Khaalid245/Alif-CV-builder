# ═══════════════════════════════════════════════════════════════════════════════
# EduCV Flutter Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to assets/env/.env and fill in your values:
#   cp .env.example assets/env/.env
# ═══════════════════════════════════════════════════════════════════════════════

# API Configuration - MUST match backend URL
# Development: http://localhost:8000/api/v1
# Production: https://api.yourdomain.com/api/v1
API_BASE_URL=http://localhost:8000/api/v1

# App Configuration
APP_NAME=EduCV
APP_VERSION=1.0.0

# Environment
# Options: development, staging, production
ENVIRONMENT=development

# CORS Configuration (informational only)
# Actual CORS validation happens on backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
