# ═══════════════════════════════════════════════════════════════════════════════
# EduCV Observability Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY: Never commit actual credentials. Use AWS Secrets Manager in production.
# Copy this file to .env.observability and fill in your values:
#   cp .env.observability.example .env.observability
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Grafana Admin Credentials ────────────────────────────────────────────────
# SECURITY: Use strong password (min 12 chars, mixed case, numbers, symbols)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-strong-password-here-min-12-chars

# ─── Sentry Error Tracking ────────────────────────────────────────────────────
# Get your DSN from https://sentry.io/settings/projects/
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SAMPLE_RATE=1.0
SENTRY_LOG_LEVEL=INFO
SENTRY_EVENT_LEVEL=ERROR
SENTRY_RELEASE=1.0.0

# ─── Monitoring Settings ──────────────────────────────────────────────────────
PROMETHEUS_METRICS_ENABLED=true
STRUCTURED_LOGGING_ENABLED=true
UPTIME_CHECK_INTERVAL=60

# ─── Alert Configuration ──────────────────────────────────────────────────────
# Email settings for alerts - use app-specific password for Gmail
ALERT_EMAIL_HOST=smtp.gmail.com
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USE_TLS=True
ALERT_EMAIL_USER=alerts@university.edu
ALERT_EMAIL_PASSWORD=your-app-password-here
ALERT_EMAIL_FROM=alerts@university.edu
ALERT_EMAIL_TO=devops@university.edu,admin@university.edu

# Slack webhook for alerts (optional)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ─── Performance Monitoring ───────────────────────────────────────────────────
# Slow query threshold (seconds)
SLOW_QUERY_THRESHOLD=1.0

# Request timeout threshold (seconds)
SLOW_REQUEST_THRESHOLD=2.0

# ─── Log Retention ────────────────────────────────────────────────────────────
# Log retention period (days)
LOG_RETENTION_DAYS=30

# Maximum log file size (MB)
LOG_MAX_SIZE_MB=100

# Number of log backup files to keep
LOG_BACKUP_COUNT=10
